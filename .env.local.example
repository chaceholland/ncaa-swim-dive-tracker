NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Required for every write path: the app's tables are RLS-protected with a
# SELECT-only anon policy, so anon-key writes silently affect 0 rows.
# Used by app/api/update, app/api/headshots, app/api/health and the scripts/
# maintenance tools. This is the privileged key — never the anon/publishable one.
#
# Primary name. Current Supabase projects issue this in the `sb_secret_…`
# format (legacy service-role JWTs were disabled 2026-04-22).
SUPABASE_SECRET_KEY=your_supabase_secret_key

# Legacy alias for the exact same key, still accepted everywhere so older
# checkouts and CI keep working. Set SUPABASE_SECRET_KEY above instead; if both
# are present, SUPABASE_SECRET_KEY wins. Do not set this to a different key.
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Shared secret for POST /api/headshots (the CSD Chrome extension sends it as
# `Authorization: Bearer <secret>`). Generate with: openssl rand -hex 32
HEADSHOT_SECRET=your_headshot_ingest_secret
