{
  "manifest_version": 3,
  "name": "CSD Roster Headshot Scraper",
  "version": "8.0.0",
  "description": "Scrape athlete headshots from team roster pages",
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "host_permissions": [
    "https://*.com/*",
    "https://*.net/*",
    "https://*.edu/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
